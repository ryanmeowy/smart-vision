{
  "tests": [
    {
      "case_id": "ht2t-001",
      "test_type": "text_to_text",
      "query": "如何降低 rerank 成本，同时保持 Recall 和 NDCG 不回退？",
      "candidates": [
        {
          "id": "txt_rel_1",
          "type": "text",
          "text": "可通过窗口化 rerank（window-size/factor/min/max）减少重排量，并用融合分避免质量明显回退。",
          "expected_relevant": true
        },
        {
          "id": "txt_rel_2",
          "type": "text",
          "text": "Rerank 成本优化目标通常同时看 P95、Recall@K、nDCG@K，不只看时延。",
          "expected_relevant": true
        },
        {
          "id": "txt_rel_3",
          "type": "text",
          "text": "当 rerank 失败时需要 fallback 到检索分排序，保障可用性与稳定性。",
          "expected_relevant": true
        },
        {
          "id": "txt_hard_neg_1",
          "type": "text",
          "text": "只要把 topK 调小就能降低成本，质量不需要监控。",
          "expected_relevant": false
        },
        {
          "id": "txt_hard_neg_2",
          "type": "text",
          "text": "OCR 成本优化主要通过压缩图片尺寸，与 rerank 无关。",
          "expected_relevant": false
        },
        {
          "id": "txt_hard_neg_3",
          "type": "text",
          "text": "向量维度越高越省钱，因此建议从 1024 提升到 4096。",
          "expected_relevant": false
        },
        {
          "id": "txt_hard_neg_4",
          "type": "text",
          "text": "分页接口 nextCursor 的签名算法设计。",
          "expected_relevant": false
        },
        {
          "id": "txt_hard_neg_5",
          "type": "text",
          "text": "图像生成模型 temperature 参数调优方法。",
          "expected_relevant": false
        },
        {
          "id": "txt_hard_neg_6",
          "type": "text",
          "text": "混合检索中 BM25 与向量召回做 RRF 融合。",
          "expected_relevant": false
        },
        {
          "id": "txt_hard_neg_7",
          "type": "text",
          "text": "线上灰度发布应先 5% 再 20% 逐步观察。",
          "expected_relevant": false
        }
      ]
    },
