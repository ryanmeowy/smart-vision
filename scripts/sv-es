#!/usr/bin/env bash
set -euo pipefail

BASE_URL="${SV_ES_BASE_URL:-http://localhost:8080}"
TOKEN="${SV_ES_TOKEN:-}"
PROFILE="${SV_ES_PROFILE:-default}"
FORMAT="json"
CONFIG_DIR="$HOME/.smartvision/escli"
CONFIG_FILE=""

ensure_config_dir() {
  mkdir -p "$CONFIG_DIR"
  chmod 700 "$CONFIG_DIR" 2>/dev/null || true
}

profile_file() {
  echo "$CONFIG_DIR/${PROFILE}.conf"
}

load_profile() {
  CONFIG_FILE="$(profile_file)"
  [[ -f "$CONFIG_FILE" ]] || return 0

  while IFS='=' read -r key value; do
    case "$key" in
      BASE_URL|SV_ES_BASE_URL)
        [[ -n "${SV_ES_BASE_URL:-}" ]] || BASE_URL="$value"
        ;;
      TOKEN|SV_ES_TOKEN)
        [[ -n "${SV_ES_TOKEN:-}" ]] || TOKEN="$value"
        ;;
      *)
        ;;
    esac
  done < "$CONFIG_FILE"
}

save_profile() {
  ensure_config_dir
  CONFIG_FILE="$(profile_file)"
  umask 077
  cat > "$CONFIG_FILE" <<EOF
BASE_URL=$BASE_URL
TOKEN=$TOKEN
EOF
  chmod 600 "$CONFIG_FILE" 2>/dev/null || true
}

print_help() {
  cat <<'USAGE'
Usage:
  sv-es [--base-url URL] [--token TOKEN] [--profile NAME] [--format json|table] <command>

Commands:
  login [--token TOKEN] [--base-url URL]
  logout
  whoami
  cluster health
  cluster stats
  index list [--pattern P] [--status green|yellow|red] [--page N] [--size N]
  index stats <index>
  mapping get <index>
  doc get <index> <id> [--source true|false]
  doc search <index> --q QUERY [--from N] [--size N] [--sort field:asc|desc] [--include field]

Examples:
  sv-es login --profile local --base-url http://localhost:8080
  sv-es --profile local cluster health
  sv-es index list --pattern 'smart_*' --format table
  sv-es doc search smart_gallery_local_read --q 'fileName:cat' --size 5 --sort createTime:desc
USAGE
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

fail() {
  echo "Error: $*" >&2
  exit 1
}

require_token() {
  [[ -n "$TOKEN" ]] || fail "Missing token. Pass --token or set SV_ES_TOKEN (or profile env file)."
}

request() {
  local method="$1"
  local path="$2"
  local data="${3:-}"

  require_token

  if [[ -n "$data" ]]; then
    curl -sS -X "$method" \
      -H "X-Access-Token: $TOKEN" \
      -H "Content-Type: application/json" \
      "$BASE_URL$path" \
      -d "$data"
  else
    curl -sS -X "$method" \
      -H "X-Access-Token: $TOKEN" \
      "$BASE_URL$path"
  fi
}

map_error_hint() {
  local code="$1"
  case "$code" in
    400) echo "Check command params (query syntax, sort field/order, size range)." ;;
    401) echo "Token invalid/expired. Run: scripts/sv-es --profile $PROFILE login" ;;
    403) echo "No permission for this index. Verify app.search.escli.allowed-index-patterns." ;;
    404) echo "Resource not found (index/doc may not exist)." ;;
    500) echo "Server side failure. Check backend logs and escli_audit entries." ;;
    *)   echo "Request failed. Check backend logs for more details." ;;
  esac
}

ensure_success() {
  local json="$1"
  if command_exists jq; then
    local code message error_id hint
    code="$(echo "$json" | jq -r '.code // 500')"
    if [[ "$code" == "200" ]]; then
      return 0
    fi
    message="$(echo "$json" | jq -r '.message // "Unknown error"')"
    error_id="$(echo "$json" | jq -r '.errorId // .requestId // empty')"
    hint="$(map_error_hint "$code")"
    echo "[$code] $message" >&2
    [[ -n "$error_id" ]] && echo "requestId: $error_id" >&2
    echo "hint: $hint" >&2
    exit 1
  fi

  if echo "$json" | grep -q '"code"[[:space:]]*:[[:space:]]*200'; then
    return 0
  fi
  echo "$json" >&2
  fail "Request failed (install jq for detailed error message)"
}

cmd_login() {
  if [[ -z "$TOKEN" ]]; then
    read -rsp "Enter access token: " TOKEN
    echo
  fi
  [[ -n "$TOKEN" ]] || fail "Token cannot be empty"
  save_profile
  echo "Login success (profile=$PROFILE, base_url=$BASE_URL)"
}

cmd_logout() {
  CONFIG_FILE="$(profile_file)"
  if [[ -f "$CONFIG_FILE" ]]; then
    rm -f "$CONFIG_FILE"
    echo "Logout success (profile=$PROFILE)"
  else
    echo "No saved login found for profile=$PROFILE"
  fi
}

cmd_whoami() {
  CONFIG_FILE="$(profile_file)"
  echo "profile=$PROFILE"
  echo "base_url=$BASE_URL"
  if [[ -n "$TOKEN" ]]; then
    echo "token=SET"
  else
    echo "token=EMPTY"
  fi
  echo "config_file=$CONFIG_FILE"
}

render_table() {
  local endpoint="$1"
  local json="$2"

  if ! command_exists jq; then
    echo "$json"
    return
  fi

  case "$endpoint" in
    cluster_health)
      echo "$json" | jq -r '
        if .code != 200 then "ERROR: " + (.message // "unknown")
        else
          ["status","clusterName","numberOfNodes","activePrimaryShards","activeShards","unassignedShards","timedOut"],
          [(.data.status // ""),(.data.clusterName // ""),(.data.numberOfNodes|tostring),(.data.activePrimaryShards|tostring),(.data.activeShards|tostring),(.data.unassignedShards|tostring),(.data.timedOut|tostring)]
          | @tsv
        end'
      ;;
    cluster_stats)
      echo "$json" | jq -r '
        if .code != 200 then "ERROR: " + (.message // "unknown")
        else
          ["clusterName","status","nodeTotal","dataNodeCount","indexCount","docCount","storeSizeBytes","shardsTotal"],
          [(.data.clusterName // ""),(.data.status // ""),(.data.nodeTotal|tostring),(.data.dataNodeCount|tostring),(.data.indexCount|tostring),(.data.docCount|tostring),(.data.storeSizeBytes|tostring),(.data.shardsTotal|tostring)]
          | @tsv
        end'
      ;;
    index_list)
      echo "$json" | jq -r '
        if .code != 200 then "ERROR: " + (.message // "unknown")
        else
          (["name","health","docsCount","storeSize","pri","rep"] | @tsv),
          (.data.items[]? | [(.name // ""),(.health // ""),(.docsCount|tostring),(.storeSize // ""),(.pri // ""),(.rep // "")] | @tsv)
        end'
      ;;
    index_stats)
      echo "$json" | jq -r '
        if .code != 200 then "ERROR: " + (.message // "unknown")
        else
          ["index","docsCount","docsDeleted","storeSizeBytes","priStoreSizeBytes","queryTotal","queryTimeInMillis"],
          [(.data.index // ""),(.data.docsCount|tostring),(.data.docsDeleted|tostring),(.data.storeSizeBytes|tostring),(.data.priStoreSizeBytes|tostring),(.data.queryTotal|tostring),(.data.queryTimeInMillis|tostring)]
          | @tsv
        end'
      ;;
    doc_get)
      echo "$json" | jq -r '
        if .code != 200 then "ERROR: " + (.message // "unknown")
        else
          ["found","index","id","version"],
          [(.data.found|tostring),(.data.index // ""),(.data.id // ""),(.data.version|tostring)]
          | @tsv
        end'
      ;;
    doc_search)
      echo "$json" | jq -r '
        if .code != 200 then "ERROR: " + (.message // "unknown")
        else
          (["id","score"] | @tsv),
          (.data.hits[]? | [(.id // ""),(.score|tostring)] | @tsv)
        end'
      ;;
    *)
      echo "$json"
      ;;
  esac
}

print_output() {
  local endpoint="$1"
  local json="$2"

  if [[ "$FORMAT" == "table" ]]; then
    render_table "$endpoint" "$json"
  else
    if command_exists jq; then
      echo "$json" | jq .
    else
      echo "$json"
    fi
  fi
}

OPT_BASE_URL=""
OPT_TOKEN=""
ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --base-url)
      OPT_BASE_URL="$2"; shift 2 ;;
    --token)
      OPT_TOKEN="$2"; shift 2 ;;
    --profile)
      PROFILE="$2"; shift 2 ;;
    --format)
      FORMAT="$2"; shift 2 ;;
    -h|--help)
      print_help; exit 0 ;;
    *)
      ARGS+=("$1"); shift ;;
  esac
done

load_profile
[[ -n "$OPT_BASE_URL" ]] && BASE_URL="$OPT_BASE_URL"
[[ -n "$OPT_TOKEN" ]] && TOKEN="$OPT_TOKEN"

set -- "${ARGS[@]}"
[[ $# -ge 1 ]] || { print_help; exit 1; }
cmd1="${1:-}"
cmd2="${2:-}"

case "$cmd1 $cmd2" in
  "login ")
    cmd_login
    ;;
  "logout ")
    cmd_logout
    ;;
  "whoami ")
    cmd_whoami
    ;;
  "cluster health")
    res="$(request GET "/api/es/cluster/health")"
    ensure_success "$res"
    print_output cluster_health "$res"
    ;;
  "cluster stats")
    res="$(request GET "/api/es/cluster/stats")"
    ensure_success "$res"
    print_output cluster_stats "$res"
    ;;
  "index list")
    shift 2
    pattern=""
    status=""
    page="1"
    size="20"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --pattern) pattern="$2"; shift 2 ;;
        --status) status="$2"; shift 2 ;;
        --page) page="$2"; shift 2 ;;
        --size) size="$2"; shift 2 ;;
        *) fail "Unknown option for index list: $1" ;;
      esac
    done
    query="?page=$page&size=$size"
    [[ -n "$pattern" ]] && query="$query&pattern=$pattern"
    [[ -n "$status" ]] && query="$query&status=$status"
    res="$(request GET "/api/es/indices$query")"
    ensure_success "$res"
    print_output index_list "$res"
    ;;
  "index stats")
    [[ $# -ge 3 ]] || fail "Usage: sv-es index stats <index>"
    index="$3"
    res="$(request GET "/api/es/indices/$index/stats")"
    ensure_success "$res"
    print_output index_stats "$res"
    ;;
  "mapping get")
    [[ $# -ge 3 ]] || fail "Usage: sv-es mapping get <index>"
    index="$3"
    res="$(request GET "/api/es/indices/$index/mapping")"
    ensure_success "$res"
    print_output mapping_get "$res"
    ;;
  "doc get")
    [[ $# -ge 4 ]] || fail "Usage: sv-es doc get <index> <id> [--source true|false]"
    index="$3"
    id="$4"
    shift 4
    source="true"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --source) source="$2"; shift 2 ;;
        *) fail "Unknown option for doc get: $1" ;;
      esac
    done
    res="$(request GET "/api/es/indices/$index/docs/$id?source=$source")"
    ensure_success "$res"
    print_output doc_get "$res"
    ;;
  "doc search")
    [[ $# -ge 3 ]] || fail "Usage: sv-es doc search <index> --q QUERY [--from N] [--size N] [--sort field:asc|desc] [--include field]"
    index="$3"
    shift 3
    query=""
    from="0"
    size="10"
    sorts=()
    includes=()

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --q) query="$2"; shift 2 ;;
        --from) from="$2"; shift 2 ;;
        --size) size="$2"; shift 2 ;;
        --sort) sorts+=("$2"); shift 2 ;;
        --include) includes+=("$2"); shift 2 ;;
        *) fail "Unknown option for doc search: $1" ;;
      esac
    done

    [[ -n "$query" ]] || fail "--q is required"

    if command_exists jq; then
      payload="$(jq -n \
        --arg q "$query" \
        --argjson from "$from" \
        --argjson size "$size" \
        --argjson sort "$(printf '%s\n' "${sorts[@]:-}" | jq -R . | jq -s 'map(select(length>0))')" \
        --argjson include "$(printf '%s\n' "${includes[@]:-}" | jq -R . | jq -s 'map(select(length>0))')" \
        '{query:$q,from:$from,size:$size,sort:$sort,sourceIncludes:$include}')"
    else
      payload="{\"query\":\"$query\",\"from\":$from,\"size\":$size}"
    fi

    res="$(request POST "/api/es/indices/$index/search" "$payload")"
    ensure_success "$res"
    print_output doc_search "$res"
    ;;
  *)
    if [[ "$cmd1" == "login" ]]; then
      cmd_login
      exit 0
    fi
    if [[ "$cmd1" == "logout" ]]; then
      cmd_logout
      exit 0
    fi
    if [[ "$cmd1" == "whoami" ]]; then
      cmd_whoami
      exit 0
    fi
    print_help
    fail "Unknown command: $*"
    ;;
esac
